---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Newsletter" description="Subscribe to the DevDiary Weekly Dispatch — one email per week covering AI agents, Claude Code, Python automation, and what I'm shipping.">
  <div class="newsletter-page">
    <div class="container">
      <div class="nl-page-inner">
        <div class="nl-page-icon">
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="var(--v2)" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M22 7l-10 6L2 7"/></svg>
        </div>
        <h1 class="nl-page-title">The Dev Diary<br/>Weekly Dispatch</h1>
        <p class="nl-page-desc">One email per week: what I shipped, what I learned, what broke, and what's next. No noise, no affiliate links — just the honest developer's log from a solo builder in Agadir.</p>

        <div class="nl-page-perks">
          <div class="perk"><span class="perk-icon">📦</span><span>New posts &amp; tutorials first</span></div>
          <div class="perk"><span class="perk-icon">🛠️</span><span>Behind-the-scenes builds</span></div>
          <div class="perk"><span class="perk-icon">💡</span><span>AI productivity tips &amp; tools</span></div>
          <div class="perk"><span class="perk-icon">🎁</span><span>Subscriber-only discounts on products</span></div>
        </div>

        <div class="nl-page-form">
          <input type="text" id="nl-name" placeholder="Your name (optional)" class="nl-input" style="font-size:15px;padding:12px 16px" aria-label="Your name" />
          <input type="email" id="nl-email" placeholder="your@email.com" class="nl-input" style="font-size:15px;padding:12px 16px" aria-label="Email address" required />
          <button class="btn btn-primary" style="justify-content:center;font-size:15px;padding:12px 28px" onclick="subscribeNewsletter()">Subscribe →</button>
          <p class="nl-feedback" id="nl-page-feedback" aria-live="polite"></p>
          <p class="nl-small">No spam. Unsubscribe any time. Free forever.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.newsletter-page { padding: 80px 0; min-height: 70vh; display: flex; align-items: center; }
.nl-page-inner { max-width: 520px; margin: 0 auto; text-align: center; }
.nl-page-icon { margin-bottom: 20px; }
.nl-page-title { font-family: var(--heading); font-weight: 700; font-size: 38px; color: var(--ink); line-height: 1.15; margin-bottom: 16px; letter-spacing: -0.03em; }
.nl-page-desc { color: var(--ink2); font-size: 16px; line-height: 1.65; margin-bottom: 28px; }
.nl-page-perks { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 32px; text-align: left; }
.perk { display: flex; align-items: center; gap: 10px; background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 11px 14px; font-size: 13.5px; color: var(--ink2); }
.perk-icon { font-size: 16px; flex-shrink: 0; }
.nl-page-form { display: flex; flex-direction: column; gap: 10px; }
.nl-page-btn { justify-content: center; font-size: 15px; padding: 12px 28px; }
.nl-small { font-size: 12px; color: var(--ink3); margin-top: 4px; }
.nl-feedback { font-size: 14px; margin-top: 8px; }
</style>

<script>
function subscribeNewsletter() {
  const email = (document.getElementById('nl-email') as HTMLInputElement)?.value.trim();
  const feedbackEl = document.getElementById('nl-page-feedback');
  if (!email || !email.includes('@')) {
    if (feedbackEl) { feedbackEl.textContent = 'Please enter a valid email address.'; feedbackEl.style.color = 'var(--coral)'; }
    document.getElementById('nl-email')?.focus();
    return;
  }
  if (feedbackEl) { feedbackEl.textContent = 'Thanks! Check your inbox for confirmation.'; feedbackEl.style.color = 'var(--teal)'; }
  (document.getElementById('nl-email') as HTMLInputElement).value = '';
}
(window as any).subscribeNewsletter = subscribeNewsletter;
</script>
