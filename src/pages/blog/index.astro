---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import CoverArt from '../../components/CoverArt.astro';
import Footer from '../../components/Footer.astro';
import { posts } from '../../data/posts';
import '../../styles/global.css';

const categories = ['All', ...new Set(posts.map((p) => p.category))];
---

<BaseLayout title="Blog — DevDiary.uk" description="All technical articles from DevDiary.uk">
  <Nav />

  <main id="main">
    <header class="blog-header container">
      <p class="section-label">// The diary</p>
      <h1>All articles</h1>
      <p class="blog-sub">
        {posts.length} posts on agentic systems, ERP automation, Claude Code, and building products solo.
      </p>
    </header>

    <div class="blog-filters container" role="group" aria-label="Filter by category">
      {categories.map((cat) => (
        <button
          class:list={['filter-btn', { active: cat === 'All' }]}
          data-category={cat}
          aria-pressed={cat === 'All' ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="divider container-divider"></div>

    <section class="blog-list container" id="post-list" aria-label="Articles">
      {posts.map((post) => (
        <article class="post-row" data-category={post.category}>
          <a href={`/blog/${post.slug}`} class="post-row-link" aria-label={post.title}>
            <div class="post-thumb">
              <CoverArt type={post.coverType} height={72} />
            </div>
            <div class="post-info">
              <div class="card-meta">
                <span class={`badge ${post.categoryStyle}`}>{post.category}</span>
                <span class="card-date font-mono">{post.date}</span>
                <span class="card-date font-mono">· {post.readTime}</span>
              </div>
              <h2 class="post-title">{post.title}</h2>
              <p class="post-desc">{post.description}</p>
            </div>
            <span class="post-arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-header {
    padding-top: var(--sp-2xl);
    padding-bottom: var(--sp-lg);
  }

  .blog-header h1 { margin-bottom: 10px; }

  .blog-sub {
    font-size: 15px;
    color: var(--ink2);
    max-width: 480px;
  }

  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    padding-bottom: var(--sp-lg);
  }

  .filter-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    padding: 6px 14px;
    border-radius: 100px;
    border: 1px solid var(--b1);
    background: var(--bg2);
    color: var(--ink3);
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: all 0.14s;
  }
  .filter-btn:hover { color: var(--ink2); border-color: var(--b2); }
  .filter-btn.active {
    background: var(--v3);
    border-color: rgba(139,121,255,.32);
    color: var(--v2);
  }

  .container-divider {
    border-bottom: 1px solid var(--b1);
    margin-inline: auto;
    max-width: var(--max-w);
    padding-inline: var(--sp-xl);
    height: 0;
    padding: 0 var(--sp-xl);
  }

  .blog-list {
    padding-block: var(--sp-lg);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-row {
    border-bottom: 1px solid var(--b1);
    transition: background 0.14s;
  }
  .post-row:hover { background: rgba(255,255,255,.018); }
  .post-row.hidden { display: none; }

  .post-row-link {
    display: grid;
    grid-template-columns: 80px 1fr 24px;
    align-items: center;
    gap: 20px;
    padding: 20px 0;
  }

  .post-thumb {
    border-radius: var(--r-sm);
    overflow: hidden;
    flex-shrink: 0;
    line-height: 0;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 8px;
  }

  .card-date { font-size: 11px; color: var(--ink3); }

  .post-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
    letter-spacing: -0.02em;
    margin-bottom: 5px;
  }

  .post-desc {
    font-size: 13px;
    color: var(--ink2);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-arrow {
    font-size: 16px;
    color: var(--ink3);
    transition: color 0.14s, transform 0.14s;
  }
  .post-row:hover .post-arrow {
    color: var(--v2);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .post-row-link { grid-template-columns: 60px 1fr; }
    .post-arrow { display: none; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const rows    = document.querySelectorAll<HTMLElement>('.post-row');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category!;

      buttons.forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');

      rows.forEach((row) => {
        const match = cat === 'All' || row.dataset.category === cat;
        row.classList.toggle('hidden', !match);
      });
    });
  });
</script>
