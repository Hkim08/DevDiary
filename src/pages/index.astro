---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Newsletter from '@/components/Newsletter.astro';
import { getAllPosts, estimateReadingTime } from '@/lib/blog';
import { products } from '@/data/products';

const posts = await getAllPosts();
const featured = posts.find(p => p.data.featured) ?? posts[0];
const recent = posts.filter(p => p?.slug !== featured?.slug).slice(0, 4);

const projectCount = 6;
const productCount = products.length;
const homeProducts = products.slice(0, 5);

const topics = [
  { name: 'AI Agents', href: '/blog/tag/ai-agents', class: 't-v' },
  { name: 'Claude Code', href: '/blog/tag/claude-code', class: 't-teal' },
  { name: 'Machine Learning', href: '/blog/tag/ml', class: 't-amber' },
  { name: 'Python', href: '/blog/tag/python', class: 't-v' },
  { name: 'Web Dev', href: '/blog/tag/web-dev', class: 't-teal' },
  { name: 'Digital Products', href: '/blog/tag/products', class: 't-amber' },
];

const expertise = [
  {
    icon: '🤖', title: 'Agentic Systems',
    desc: 'Real architectures for autonomous agents — memory design, tool use, approval gates, multi-specialist teams, and production pitfalls.',
    chips: ['Claude Code', 'OpenClaw', 'SQLite memory', 'MCP'], class: 'c1', iconClass: 'v',
  },
  {
    icon: '⚙️', title: 'ERP & Enterprise AI',
    desc: 'Applying AI to SAP and ERP consulting workflows — audit automation, documentation agents, and migration tooling that actually ships.',
    chips: ['SAP', 'ERP', 'Python', 'TypeScript'], class: 'c2', iconClass: 'teal',
  },
  {
    icon: '🚀', title: 'Building in Public',
    desc: 'Shipping digital products solo — prompt packs, PDF blueprints, Gumroad launches, and the honest numbers behind each one.',
    chips: ['Gumroad', 'DevDiary', 'PDF pipelines', 'Astro'], class: 'c3', iconClass: 'amber',
  },
];
---

<BaseLayout title="DevDiary.uk — AI dev diaries from a solo builder" description="Deep technical writing from a solo ERP consultant building agentic systems, Claude Code workflows, and AI-native products.">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-kicker">
        <span class="kicker-badge">v2.0 · AI Dev Blog</span>
        <div class="kicker-pulse" aria-hidden="true"></div>
        <span class="kicker-live">Building in public</span>
      </div>
      <h1>Where <span class="hl">AI agents</span><br>meet real-world<br>engineering</h1>
      <p class="hero-sub">Deep technical writing from a solo ERP consultant building agentic systems, Claude Code workflows, and AI-native products — live, from Agadir.</p>
      <div class="hero-actions">
        <a href="/blog" class="btn-hero primary">Read the diary ↓</a>
        <a href="/products" class="btn-hero ghost">Browse products →</a>
      </div>
      <div class="hero-tags">
        {topics.map(t => <a href={t.href} class={`tag hero-tag ${t.class}`}>{t.name}</a>)}
      </div>
    </div>
    <div class="hero-right">
      <canvas id="heroCanvas" class="hero-canvas" aria-hidden="true"></canvas>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="stats-strip">
    <div class="stat-cell">
      <div class="stat-icon v"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C3BBFF" stroke-width="1.5"><path d="M12 2a10 10 0 0 1 10 10c0 5-4 8-10 8S2 17 2 12 7 2 12 2z"/><path d="M12 6v6l4 2"/></svg></div>
      <div><div class="stat-num">12+</div><div class="stat-label">AI agents built</div></div>
    </div>
    <div class="stat-cell">
      <div class="stat-icon teal"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#5EEAD4" stroke-width="1.5"><rect x="2" y="3" width="20" height="18" rx="3"/><path d="M8 9h8M8 13h6M8 17h4"/></svg></div>
      <div><div class="stat-num">{productCount}+</div><div class="stat-label">Digital products</div></div>
    </div>
    <div class="stat-cell">
      <div class="stat-icon amber"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FCD34D" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="M9 15l3-3 3 3"/></svg></div>
      <div><div class="stat-num">{posts.length}+</div><div class="stat-label">Technical articles</div></div>
    </div>
    <div class="stat-cell">
      <div class="stat-icon pink"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F9A8D4" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg></div>
      <div><div class="stat-num">400+</div><div class="stat-label">Weekly readers</div></div>
    </div>
  </div>

  <!-- FEATURED POSTS -->
  {posts.length > 0 && (
    <div class="section" style="padding-bottom:16px">
      <div class="section-header">
        <h2 id="posts-heading" class="section-title">Featured from the diary</h2>
        <a href="/blog" class="see-all">All posts →</a>
      </div>
      <div class="featured-grid">
        {featured && (
          <a href={`/blog/${featured.slug}`} class="card-big" aria-label={featured.data.title}>
            <div class="card-hero-bg">
              <svg width="100%" height="100%" viewBox="0 0 320 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Network visualization">
                <defs>
                  <radialGradient id="cg1" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#8B79FF" stop-opacity="0.4"/><stop offset="100%" stop-color="#8B79FF" stop-opacity="0"/></radialGradient>
                  <radialGradient id="cg2" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#2DD4BF" stop-opacity="0.35"/><stop offset="100%" stop-color="#2DD4BF" stop-opacity="0"/></radialGradient>
                </defs>
                <ellipse cx="160" cy="100" rx="90" ry="70" fill="url(#cg1)"/>
                <ellipse cx="240" cy="60" rx="50" ry="40" fill="url(#cg2)"/>
                {Array.from({length:5}, (_,i) => <line key={`gl-${i}`} x1="0" y1={40+i*40} x2="320" y2={40+i*40} stroke="rgba(139,121,255,.1)" stroke-width=".5"/>)}
                {Array.from({length:4}, (_,i) => <line key={`gv-${i}`} x1={80+i*80} y1="0" x2={80+i*80} y2="200" stroke="rgba(139,121,255,.1)" stroke-width=".5"/>)}
                <circle cx="40" cy="70" r="5" fill="none" stroke="#8B79FF" stroke-width="1.5"/>
                <circle cx="40" cy="110" r="5" fill="none" stroke="#8B79FF" stroke-width="1.5"/>
                <circle cx="40" cy="150" r="5" fill="none" stroke="#8B79FF" stroke-width="1.5"/>
                <circle cx="120" cy="60" r="6" fill="rgba(139,121,255,.3)" stroke="#8B79FF" stroke-width="1.5"/>
                <circle cx="120" cy="100" r="6" fill="rgba(139,121,255,.3)" stroke="#8B79FF" stroke-width="1.5"/>
                <circle cx="120" cy="140" r="6" fill="rgba(139,121,255,.3)" stroke="#8B79FF" stroke-width="1.5"/>
                <circle cx="200" cy="80" r="7" fill="rgba(45,212,191,.25)" stroke="#2DD4BF" stroke-width="1.5"/>
                <circle cx="200" cy="120" r="7" fill="rgba(45,212,191,.25)" stroke="#2DD4BF" stroke-width="1.5"/>
                <circle cx="280" cy="100" r="6" fill="rgba(195,187,255,.3)" stroke="#C3BBFF" stroke-width="1.5"/>
                {[[45,70,114,63],[45,70,114,100],[45,110,114,100],[45,110,114,140],[45,150,114,140],[126,63,193,82],[126,100,193,82],[126,100,193,120],[126,140,193,120],[207,82,274,100],[207,120,274,100]].map(([x1,y1,x2,y2],i) => <line key={`conn-${i}`} x1={x1} y1={y1} x2={x2} y2={y2} stroke={i>9?'#2DD4BF':'#8B79FF'} stroke-opacity={i>9?".4":".35"} stroke-width=".8"/>)}
                <text x="160" y="186" fill="#8B79FF" fill-opacity=".6" font-size="9" text-anchor="middle" font-family="JetBrains Mono, monospace" letter-spacing=".08em">MULTI-AGENT ARCHITECTURE</text>
              </svg>
            </div>
            <div class="card-body">
              <div class="card-meta">
                <span class="card-cat" style="background:var(--v3);color:var(--v2);border:1px solid rgba(139,121,255,.25)">{featured.data.tags[0] ?? 'AI Agents'}</span>
                <span class="card-date">{new Date(featured.data.pubDate).toLocaleDateString('en-GB', {month:'short',year:'numeric'})}</span>
              </div>
              <div class="card-title">{featured.data.title}</div>
              <div class="card-desc">{featured.data.description}</div>
            </div>
            <div class="card-footer">
              <span class="read-time">{estimateReadingTime(featured.body)} min read</span>
              <span class="arrow-btn">Read article →</span>
            </div>
          </a>
        )}
        <div class="cards-stack">
          {recent.slice(0, 3).map(post => (
            <a key={post.slug} href={`/blog/${post.slug}`} class="card-sm" aria-label={post.data.title}>
              <div class="card-sm-thumb" style={`background:linear-gradient(135deg,${post.data.tags[0]==='ml'?'#0B1A12,#0D2520':post.data.tags[0]==='products'?'#0F0B00,#1F1500':'#0A0014,#160028'})`}>
                <svg width="50" height="50" viewBox="0 0 50 50" aria-hidden="true">
                  <circle cx="25" cy="25" r="18" fill="none" stroke="#2DD4BF" stroke-width="1" stroke-opacity=".4"/>
                  <circle cx="25" cy="25" r="10" fill="none" stroke="#2DD4BF" stroke-width="1.5" stroke-opacity=".6"/>
                  <circle cx="25" cy="25" r="4" fill="#2DD4BF" fill-opacity=".7"/>
                  <line x1="25" y1="7" x2="25" y2="15" stroke="#2DD4BF" stroke-width="1" stroke-opacity=".5"/>
                  <line x1="25" y1="35" x2="25" y2="43" stroke="#2DD4BF" stroke-width="1" stroke-opacity=".5"/>
                  <line x1="7" y1="25" x2="15" y2="25" stroke="#2DD4BF" stroke-width="1" stroke-opacity=".5"/>
                  <line x1="35" y1="25" x2="43" y2="25" stroke="#2DD4BF" stroke-width="1" stroke-opacity=".5"/>
                </svg>
              </div>
              <div class="card-sm-body">
                <div class="card-meta" style="margin-bottom:5px">
                  <span class="card-cat" style={`background:${post.data.tags[0]==='ml'?'rgba(45,212,191,.1);color:#5EEAD4;border:1px solid rgba(45,212,191,.2)':post.data.tags[0]==='products'?'rgba(245,158,11,.1);color:#FCD34D;border:1px solid rgba(245,158,11,.2)':'var(--v3);color:var(--v2);border:1px solid rgba(139,121,255,.25)'}`}>{post.data.tags[0]}</span>
                  <span class="card-date">{new Date(post.data.pubDate).toLocaleDateString('en-GB', {month:'short',year:'numeric'})}</span>
                </div>
                <div class="card-sm-title">{post.data.title}</div>
                <div class="card-sm-desc">{post.data.description}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- EXPERTISE -->
  <div class="expertise">
    <div class="section-header">
      <h2 id="expertise-heading" class="section-title">What I write about</h2>
    </div>
    <div class="exp-grid">
      {expertise.map(e => (
        <div class={`exp-card ${e.class}`}>
          <span class={`exp-icon ${e.iconClass}`} aria-hidden="true">{e.icon}</span>
          <div class="exp-title">{e.title}</div>
          <div class="exp-desc">{e.desc}</div>
          <div class="exp-tags">
            {e.chips.map(c => <span class="exp-chip">{c}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- NEWSLETTER -->
  <Newsletter />

  <!-- PRODUCTS TEASER -->
  {homeProducts.length > 0 && (
    <div class="products-teaser">
      <div class="section-header">
        <h2 class="section-title">Info-products & tools</h2>
        <a href="/products" class="see-all">All products →</a>
      </div>
      <div class="products-grid">
        {homeProducts.map(p => (
          <article class="product-card" class:list={p.badge?.includes('BESTSELLER') ? 'product-card--featured' : ''} onclick={`window.location='/products/${p.slug}'`} role="link" tabindex="0" onkeydown={`if(event.key==='Enter')window.location='/products/${p.slug}'`}>
            {p.badge && <div class="product-badge">{p.badge}</div>}
            <div class="product-name">{p.name}</div>
            <p class="product-desc">{p.desc}</p>
            <div class="product-price">
              <span class="price-val">${p.price}</span>
              <span class="price-note">one-time · Gumroad</span>
            </div>
            <div class="product-card-actions">
              <a href={`/products/${p.slug}`} class="btn btn-ghost product-btn">Details →</a>
              <a href={p.gumroadUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost product-btn buy-btn" onclick="event.stopPropagation()">Buy →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  )}
</BaseLayout>

<style>
.hero { display: grid; grid-template-columns: 1fr 1fr; gap: 0; min-height: 420px; border-bottom: 1px solid var(--border); }
.hero-left { padding: 52px 40px; display: flex; flex-direction: column; justify-content: center; border-right: 1px solid var(--border); }
.hero-kicker { display: inline-flex; align-items: center; gap: 7px; margin-bottom: 22px; }
.kicker-badge { background: var(--v3); border: 1px solid rgba(139,121,255,0.3); border-radius: 100px; padding: 4px 11px; font-size: 11px; font-family: var(--mono); color: var(--v2); letter-spacing: 0.06em; }
.kicker-pulse { width: 6px; height: 6px; border-radius: 50%; background: var(--teal); animation: blink 2s ease-in-out infinite; flex-shrink: 0; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.25} }
.kicker-live { font-size: 11px; font-family: var(--mono); color: var(--ink3); letter-spacing: 0.04em; }
.hero h1 { font-family: var(--heading); font-size: clamp(30px, 3.8vw, 46px); font-weight: 700; line-height: 1.12; letter-spacing: -0.035em; color: var(--ink); margin-bottom: 16px; }
.hero h1 .hl { background: linear-gradient(90deg, var(--v) 0%, var(--teal) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero-sub { font-size: 15px; color: var(--ink2); line-height: 1.65; max-width: 420px; margin-bottom: 28px; }
.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px; }
.btn-hero { padding: 10px 20px; border-radius: 8px; font-size: 13.5px; font-weight: 500; cursor: pointer; font-family: inherit; transition: all var(--transition); display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
.btn-hero.primary { background: var(--v); border: none; color: #fff; }
.btn-hero.primary:hover { opacity: 0.85; transform: translateY(-1px); }
.btn-hero.ghost { background: transparent; border: 1px solid var(--border2); color: var(--ink2); }
.btn-hero.ghost:hover { border-color: rgba(255,255,255,0.22); color: var(--ink); text-decoration: none; }
.hero-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.hero-tag { font-size: 10.5px; font-family: var(--mono); padding: 4px 10px; border-radius: 5px; background: var(--bg3); border: 1px solid var(--border); color: var(--ink3); letter-spacing: 0.03em; cursor: pointer; text-decoration: none; transition: all var(--transition); }
.hero-tag:hover { opacity: 0.8; }
.hero-tag.t-v { background: var(--v3); border-color: rgba(139,121,255,.25); color: var(--v2); }
.hero-tag.t-teal { background: rgba(45,212,191,.08); border-color: rgba(45,212,191,.25); color: #5EEAD4; }
.hero-tag.t-amber { background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.25); color: #FCD34D; }

.hero-right { padding: 32px; display: flex; align-items: center; justify-content: center; background: var(--bg2); position: relative; overflow: hidden; }
.hero-canvas { width: 100%; height: 340px; }

.stats-strip { display: grid; grid-template-columns: repeat(4, 1fr); border-bottom: 1px solid var(--border); }
.stat-cell { padding: 20px 28px; border-right: 1px solid var(--border); display: flex; align-items: center; gap: 14px; }
.stat-cell:last-child { border-right: none; }
.stat-icon { width: 36px; height: 36px; border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.stat-icon.v { background: var(--v3); }
.stat-icon.teal { background: rgba(45,212,191,.1); }
.stat-icon.amber { background: rgba(245,158,11,.1); }
.stat-icon.pink { background: rgba(236,72,153,.1); }
.stat-num { font-family: var(--heading); font-size: 22px; font-weight: 700; color: var(--ink); letter-spacing: -0.03em; line-height: 1; }
.stat-label { font-size: 11px; color: var(--ink3); margin-top: 2px; letter-spacing: 0.02em; text-transform: uppercase; }

.section { padding: 40px; }

.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.section-title { font-family: var(--heading); font-size: 13px; font-weight: 600; color: var(--ink2); letter-spacing: .06em; text-transform: uppercase; display: flex; align-items: center; gap: 10px; }
.section-title::before { content: ''; width: 18px; height: 2px; background: var(--v); border-radius: 2px; flex-shrink: 0; }
.see-all { font-size: 13px; color: var(--ink3); text-decoration: none; display: flex; align-items: center; gap: 4px; transition: color var(--transition); }
.see-all:hover { color: var(--v2); }

.featured-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 16px; margin-bottom: 16px; }
.card-big { background: var(--bg2); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; cursor: pointer; transition: border-color .2s, transform .2s; text-decoration: none; color: inherit; display: flex; flex-direction: column; }
.card-big:hover { border-color: rgba(139,121,255,.35); transform: translateY(-2px); }
.card-hero-bg { height: 200px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: linear-gradient(135deg,#0D0B1E 0%,#1A1040 50%,#0B1A2A 100%); }
.card-body { padding: 20px; flex: 1; }
.card-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.card-cat { font-size: 10px; font-family: var(--mono); padding: 3px 8px; border-radius: 4px; letter-spacing: .05em; font-weight: 500; text-transform: uppercase; }
.card-date { font-size: 11px; color: var(--ink3); font-family: var(--mono); }
.card-title { font-family: var(--heading); font-size: 17px; font-weight: 700; color: var(--ink); line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 8px; }
.card-desc { font-size: 13px; color: var(--ink2); line-height: 1.6; }
.card-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.read-time { font-size: 11px; color: var(--ink3); font-family: var(--mono); }
.arrow-btn { font-size: 13px; color: var(--v2); display: flex; align-items: center; gap: 4px; font-weight: 500; }

.cards-stack { display: flex; flex-direction: column; gap: 12px; }
.card-sm { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; cursor: pointer; transition: border-color .2s, transform .15s; display: grid; grid-template-columns: 80px 1fr; text-decoration: none; color: inherit; }
.card-sm:hover { border-color: rgba(139,121,255,.3); transform: translateX(2px); }
.card-sm-thumb { display: flex; align-items: center; justify-content: center; }
.card-sm-body { padding: 14px 16px; }
.card-sm-title { font-family: var(--heading); font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.35; letter-spacing: -0.015em; margin-bottom: 5px; }
.card-sm-desc { font-size: 12px; color: var(--ink2); line-height: 1.5; }

.expertise { padding: 0 40px 40px; }
.exp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.exp-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 22px; position: relative; overflow: hidden; transition: border-color .2s; }
.exp-card:hover { border-color: rgba(139,121,255,.3); }
.exp-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
.exp-card.c1::before { background: linear-gradient(90deg, var(--v), var(--v2)); }
.exp-card.c2::before { background: linear-gradient(90deg, var(--teal), #67E8F9); }
.exp-card.c3::before { background: linear-gradient(90deg, var(--amber), #FDE68A); }
.exp-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 14px; }
.exp-icon.v { background: var(--v3); }
.exp-icon.teal { background: rgba(45,212,191,.1); }
.exp-icon.amber { background: rgba(245,158,11,.08); }
.exp-title { font-family: var(--heading); font-size: 15px; font-weight: 700; color: var(--ink); letter-spacing: -0.02em; margin-bottom: 8px; }
.exp-desc { font-size: 12.5px; color: var(--ink2); line-height: 1.6; margin-bottom: 14px; }
.exp-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.exp-chip { font-size: 10px; font-family: var(--mono); padding: 3px 7px; border-radius: 4px; background: var(--bg3); border: 1px solid var(--border); color: var(--ink3); letter-spacing: .03em; }

.products-teaser { padding: 16px 40px 80px; }
.products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.product-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 22px; position: relative; overflow: hidden; transition: border-color var(--transition), transform var(--transition); display: flex; flex-direction: column; cursor: pointer; }
.product-card:hover { border-color: rgba(139,121,255,.3); transform: translateY(-2px); }
.product-card--featured { border-color: rgba(139,121,255,.35); background: linear-gradient(135deg, var(--bg2) 0%, rgba(139,121,255,0.05) 100%); }
.product-badge { position: absolute; top: 12px; right: 12px; font-family: var(--mono); font-size: 10px; padding: 2px 8px; border-radius: 4px; background: rgba(245,158,11,.15); color: var(--amber); font-weight: 600; letter-spacing: .03em; }
.product-name { font-family: var(--heading); font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
.product-desc { font-size: 13px; color: var(--ink2); line-height: 1.55; margin-bottom: 14px; flex: 1; }
.product-price { display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px; }
.price-val { font-family: var(--heading); font-size: 18px; font-weight: 700; color: var(--teal); }
.price-note { font-size: 12px; color: var(--ink3); }
.product-card-actions { display: flex; align-items: center; gap: 10px; margin-top: 14px; }
.product-btn { font-size: 13px; padding: 8px 16px; border-radius: 8px; text-decoration: none; transition: all var(--transition); }
.product-btn.buy-btn { padding: 8px 16px; border-radius: 8px; background: var(--v); color: #fff; border: none; }
.product-btn.buy-btn:hover { opacity: 0.85; }

@media (max-width: 768px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-left { padding: 36px 24px; border-right: none; }
  .hero-right { display: none; }
  .stats-strip { grid-template-columns: repeat(2, 1fr); }
  .stat-cell { padding: 16px 20px; }
  .stat-cell:nth-child(2) { border-right: none; }
  .featured-grid { grid-template-columns: 1fr; }
  .exp-grid { grid-template-columns: 1fr; }
  .products-grid { grid-template-columns: 1fr; }
  .section { padding: 24px; }
  .expertise { padding: 0 24px 24px; }
  .products-teaser { padding: 16px 24px 60px; }
}
</style>

<script>
const canvas = document.getElementById('heroCanvas');
if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
  const ctx = canvas.getContext('2d');
  let W, H, nodes = [], frame = 0;

  function resize() {
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    initNodes();
  }

  function initNodes() {
    nodes = [];
    const count = 28;
    for (let i = 0; i < count; i++) {
      nodes.push({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - .5) * .4, vy: (Math.random() - .5) * .4,
        r: Math.random() * 2.5 + 1.5,
        hue: Math.random() > .6 ? '139,121,255' : '45,212,191',
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#10101A';
    ctx.fillRect(0, 0, W, H);

    ctx.strokeStyle = 'rgba(139,121,255,0.06)';
    ctx.lineWidth = .5;
    const gs = 40;
    for (let x = 0; x < W; x += gs) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
    for (let y = 0; y < H; y += gs) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }

    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y;
        const d = Math.sqrt(dx * dx + dy * dy);
        if (d < 100) {
          const a = (1 - d / 100) * .35;
          ctx.beginPath();
          ctx.strokeStyle = `rgba(139,121,255,${a})`;
          ctx.lineWidth = .7;
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.stroke();
        }
      }
    }

    nodes.forEach(n => {
      const pulse = Math.sin(frame * .02 + n.x) * .3 + .7;
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${n.hue},${pulse})`;
      ctx.fill();
      ctx.strokeStyle = `rgba(${n.hue},0.6)`;
      ctx.lineWidth = 1;
      ctx.stroke();
      n.x += n.vx; n.y += n.vy;
      if (n.x < 0 || n.x > W) n.vx *= -1;
      if (n.y < 0 || n.y > H) n.vy *= -1;
    });

    const t = frame * .008;
    ctx.font = '10px JetBrains Mono, monospace';
    const snippets = [
      { text: '> agent.run()', x: .15, y: .25, c: 'rgba(139,121,255,0.25)' },
      { text: 'const arc = new BizOS()', x: .5, y: .6, c: 'rgba(195,187,255,0.2)' },
      { text: '> dispatch(specialist)', x: .65, y: .2, c: 'rgba(45,212,191,0.2)' },
      { text: 'tools: [search, write, code]', x: .08, y: .72, c: 'rgba(139,121,255,0.18)' },
      { text: '> mcp.connect()', x: .55, y: .82, c: 'rgba(45,212,191,0.18)' },
    ];
    snippets.forEach(s => {
      const yo = Math.sin(t + s.x * 10) * .8;
      ctx.fillStyle = s.c;
      ctx.fillText(s.text, s.x * W, s.y * H + yo);
    });

    frame++;
    requestAnimationFrame(draw);
  }

  resize();
  window.addEventListener('resize', resize);
  draw();
}
</script>
