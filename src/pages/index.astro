---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StatsStrip from '../components/StatsStrip.astro';
import PostsGrid from '../components/PostsGrid.astro';
import Expertise from '../components/Expertise.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="DevDiary.uk — Where AI Agents Meet Real-World Engineering"
  description="Deep technical writing from a solo ERP consultant building agentic systems, Claude Code workflows, and AI-native products — live, from Agadir."
>
  <Nav />

  <main id="main">
    <Hero />
    <StatsStrip />
    <PostsGrid />
    <Expertise />
    <Newsletter />
  </main>

  <Footer />
</BaseLayout>

