---
import SEOHead from '@/components/SEOHead.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  canonicalUrl?: string;
  noindex?: boolean;
}
---

<!doctype html>
<html lang="en-GB">
  <head>
    <SEOHead {...Astro.props} />
  </head>
  <body>
    <Nav />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
