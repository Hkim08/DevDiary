---
// src/components/StatsStrip.astro

const stats = [
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4a4 4 0 0 1 3.5 6A4 4 0 1 1 12 4z"/><path d="M12 18v2"/><path d="M8 12H6"/><path d="M18 12h-2"/></svg>',
    num: '12+', label: 'AI agents built',   color: 'v'
  },
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>',
    num: '6+',  label: 'Digital products',  color: 'teal'
  },
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>',
    num: '4+',  label: 'Technical articles', color: 'amber'
  },
  {
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
    num: '400+',label: 'Weekly readers',    color: 'pink'
  },
];
---

<div class="stats-strip" role="list" aria-label="Key stats">
  {stats.map((s) => (
    <div class="stat-cell" role="listitem">
      <div class={`stat-icon stat-icon--${s.color}`} aria-hidden="true" set:html={s.icon}></div>
      <div>
        <div class="stat-num font-display">{s.num}</div>
        <div class="stat-label font-mono">{s.label}</div>
      </div>
    </div>
  ))}
</div>

<style>
  .stats-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--b1);
  }

  .stat-cell {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px 28px;
    border-right: 1px solid var(--b1);
  }
  .stat-cell:last-child { border-right: none; }

  .stat-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink2);
    flex-shrink: 0;
  }
  .stat-icon--v     { background: var(--v3); }
  .stat-icon--teal  { background: rgba(45,212,191,.1); }
  .stat-icon--amber { background: rgba(245,158,11,.1); }
  .stat-icon--pink  { background: rgba(236,72,153,.1); }

  .stat-num {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 10.5px;
    color: var(--ink3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 3px;
  }

  @media (max-width: 640px) {
    .stats-strip { grid-template-columns: 1fr 1fr; }
    .stat-cell:nth-child(2) { border-right: none; }
    .stat-cell { padding: 16px 20px; }
  }
</style>
