---
// src/components/Expertise.astro

const areas = [
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>',
    iconBg: 'v',
    accentGradient: 'linear-gradient(90deg,#8B79FF,#C3BBFF)',
    title: 'Agentic Systems',
    desc: 'Real architectures for autonomous agents — memory design, tool use, approval gates, multi-specialist teams, and production pitfalls you won\'t find in tutorials.',
    chips: ['Claude Code', 'OpenClaw', 'SQLite memory', 'MCP', 'TypeScript'],
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
    iconBg: 'teal',
    accentGradient: 'linear-gradient(90deg,#2DD4BF,#67E8F9)',
    title: 'ERP & Enterprise AI',
    desc: 'Applying AI to SAP and ERP consulting workflows — audit automation, documentation agents, and migration tooling that actually ships to real clients.',
    chips: ['SAP', 'ERP', 'ABAP', 'Python', 'TypeScript'],
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3 2-6 6 2 3 3-2 6-6-2z"/><path d="M12 15l-3 3"/><path d="M15 12l3 3"/></svg>',
    iconBg: 'amber',
    accentGradient: 'linear-gradient(90deg,#F59E0B,#FDE68A)',
    title: 'Building in Public',
    desc: 'Shipping digital products solo — prompt packs, PDF blueprints, Gumroad launches, and the honest numbers behind each one. No hype, just the build log.',
    chips: ['Gumroad', 'DevDiary', 'Astro', 'PDF pipelines', 'Landing pages'],
  },
];
---

<section class="expertise container" aria-labelledby="expertise-heading">
  <h2 class="section-label" id="expertise-heading">What I write about</h2>

  <div class="exp-grid">
    {areas.map((area) => (
      <div class="exp-card">
        <div class="exp-accent" style={`background: ${area.accentGradient}`} aria-hidden="true"></div>
        <div class={`exp-icon exp-icon--${area.iconBg}`} aria-hidden="true" set:html={area.icon}></div>
        <h3 class="exp-title">{area.title}</h3>
        <p class="exp-desc">{area.desc}</p>
        <div class="exp-tags" aria-label="Technologies">
          {area.chips.map((chip) => (
            <span class="exp-chip font-mono">{chip}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .expertise {
    padding-bottom: var(--sp-2xl);
  }

  .exp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .exp-card {
    position: relative;
    background: var(--bg2);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    padding: 24px;
    overflow: hidden;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .exp-card:hover {
    border-color: rgba(139,121,255,.28);
    transform: translateY(-2px);
  }

  .exp-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: var(--r-lg) var(--r-lg) 0 0;
  }

  .exp-icon {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 16px;
  }
  .exp-icon--v     { background: var(--v3); }
  .exp-icon--teal  { background: rgba(45,212,191,.1); }
  .exp-icon--amber { background: rgba(245,158,11,.08); }

  .exp-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .exp-desc {
    font-size: 13px;
    color: var(--ink2);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .exp-chip {
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 5px;
    background: var(--bg3);
    border: 1px solid var(--b1);
    color: var(--ink3);
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .exp-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .exp-grid { grid-template-columns: 1fr; }
  }
</style>
