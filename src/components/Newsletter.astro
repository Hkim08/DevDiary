---
// src/components/Newsletter.astro
---

<section class="newsletter-wrap" id="newsletter" aria-labelledby="newsletter-heading">
  <div class="nl-card">
    <div class="nl-left">
      <div class="nl-overline font-mono">// weekly dispatch</div>
      <h2 id="newsletter-heading">The Dev Diary<br />Weekly</h2>
      <p class="nl-sub">What I shipped, what broke, what I learned. One honest email per week from a solo AI builder.</p>
    </div>

    <div class="nl-right">
      <ul class="nl-perks" role="list">
        <li class="perk-item">
          <span class="perk-check" aria-hidden="true">✓</span>
          New articles & tutorials, first
        </li>
        <li class="perk-item">
          <span class="perk-check" aria-hidden="true">✓</span>
          Behind-the-scenes build logs
        </li>
        <li class="perk-item">
          <span class="perk-check" aria-hidden="true">✓</span>
          Subscriber-only product discounts
        </li>
      </ul>

      <form class="nl-form" id="nl-form" novalidate>
        <label for="nl-email" class="sr-only">Email address</label>
        <input
          id="nl-email"
          class="nl-input"
          type="email"
          name="email"
          placeholder="your@email.com"
          autocomplete="email"
          required
        />
        <button type="submit" class="btn btn-primary" id="nl-submit">
          Join free →
        </button>
      </form>
      <p class="nl-note font-mono">400+ readers · no spam · unsubscribe any time</p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('nl-form');
  const btn = document.getElementById('nl-submit');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (document.getElementById('nl-email') as HTMLInputElement).value;
    if (!email) return;
    btn.textContent = 'Subscribed!';
    btn.disabled = true;
    btn.style.opacity = '0.6';
    form.querySelector('.nl-note')!.textContent = '✓ Check your inbox for confirmation';
  });
</script>

<style>
  .newsletter-wrap {
    max-width: 920px;
    margin-inline: auto;
    padding-bottom: var(--sp-2xl);
  }

  .nl-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--bg2);
    border: 1px solid var(--b2);
    border-radius: var(--r-xl);
    overflow: hidden;
  }

  .nl-left {
    padding: 40px 44px;
    background: linear-gradient(135deg, rgba(139,121,255,.1) 0%, rgba(45,212,191,.05) 100%);
    border-right: 1px solid var(--b1);
  }

  .nl-overline {
    font-size: 10.5px;
    color: var(--v2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .nl-left h2 {
    font-size: clamp(22px, 2.5vw, 30px);
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .nl-sub {
    font-size: 13.5px;
    color: var(--ink2);
    line-height: 1.65;
  }

  .nl-right {
    padding: 40px 44px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
  }

  .nl-perks {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .perk-item {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 13px;
    color: var(--ink2);
  }

  .perk-check {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: var(--v3);
    border: 1px solid rgba(139,121,255,.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--v2);
    font-weight: 700;
    flex-shrink: 0;
  }

  .nl-form {
    display: flex;
    gap: 8px;
  }

  .nl-input {
    flex: 1;
    background: var(--bg3);
    border: 1px solid var(--b2);
    color: var(--ink);
    padding: 10px 14px;
    border-radius: var(--r-md);
    font-size: 13.5px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }
  .nl-input:focus { border-color: rgba(139,121,255,.52); }
  .nl-input::placeholder { color: var(--ink3); }

  .nl-note {
    font-size: 11px;
    color: var(--ink3);
  }

  /* sr-only utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .nl-card { grid-template-columns: 1fr; }
    .nl-left { border-right: none; border-bottom: 1px solid var(--b1); padding: 32px; }
    .nl-right { padding: 32px; }
  }

  @media (max-width: 480px) {
    .nl-form { flex-direction: column; }
  }
</style>
