---
// src/components/Hero.astro
---

<section class="hero" aria-label="Introduction">
  <div class="hero-left">
    <div class="hero-kicker">
      <span class="badge accent">v2.0 · AI Dev Blog</span>
      <span class="live-dot" aria-hidden="true"></span>
      <span class="live-label font-mono">Building in public</span>
    </div>

    <h1>
      Where <em class="gradient-text">AI agents</em><br />
      meet real&#8209;world<br />
      engineering
    </h1>

    <p class="hero-sub">
      Deep technical writing from a solo ERP consultant building agentic systems,
      Claude Code workflows, and AI&#8209;native products — live, from Agadir.
    </p>

    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary">Read the diary ↓</a>
      <a href="https://gumroad.com/rachidhakim" target="_blank" rel="noopener" class="btn btn-ghost">Browse products →</a>
    </div>

    <div class="hero-tags" role="list" aria-label="Topics covered">
      <span class="badge accent" role="listitem">AI Agents</span>
      <span class="badge teal" role="listitem">Claude Code</span>
      <span class="badge amber" role="listitem">OpenClaw</span>
      <span class="badge" role="listitem">TypeScript</span>
      <span class="badge" role="listitem">ERP / SAP</span>
      <span class="badge" role="listitem">Python</span>
    </div>
  </div>

  <div class="hero-right" aria-hidden="true">
    <canvas id="hero-canvas"></canvas>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 440px;
    border-bottom: 1px solid var(--b1);
  }

  /* ── Left panel ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    padding: 56px var(--sp-xl);
    border-right: 1px solid var(--b1);
  }

  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 22px;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
    animation: pulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.2; }
  }

  .live-label {
    font-size: 11.5px;
    color: var(--ink3);
    letter-spacing: 0.04em;
  }

  h1 {
    margin-bottom: 18px;
  }
  h1 em { font-style: normal; }

  .hero-sub {
    font-size: 15.5px;
    color: var(--ink2);
    line-height: 1.68;
    max-width: 430px;
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 26px;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* ── Right panel — canvas ── */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg2);
    overflow: hidden;
    position: relative;
  }

  #hero-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-right {
      height: 260px;
      border-top: 1px solid var(--b1);
    }
    .hero-left {
      padding: 40px var(--sp-lg);
      border-right: none;
    }
  }
</style>

<script>
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('canvas not found');
  const ctx = canvas.getContext('2d')!;

  interface Node {
    x: number; y: number;
    vx: number; vy: number;
    r: number;
    hue: string;
    phase: number;
  }

  let W = 0, H = 0;
  let nodes: Node[] = [];
  let frame = 0;
  let raf = 0;

  const NODE_COUNT = 30;

  const SNIPPETS = [
    { text: '> agent.run()', xr: 0.14, yr: 0.22 },
    { text: 'const arc = new BizOS()', xr: 0.44, yr: 0.58 },
    { text: '> dispatch(specialist)', xr: 0.60, yr: 0.18 },
    { text: 'tools: [search, write, code]', xr: 0.06, yr: 0.74 },
    { text: '> mcp.connect()', xr: 0.52, yr: 0.84 },
    { text: 'SOUL.md loaded ✓', xr: 0.70, yr: 0.68 },
  ];

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    initNodes();
  }

  function initNodes() {
    nodes = Array.from({ length: NODE_COUNT }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.42,
      vy: (Math.random() - 0.5) * 0.42,
      r: Math.random() * 2.4 + 1.4,
      hue: Math.random() > 0.55 ? '139,121,255' : '45,212,191',
      phase: Math.random() * Math.PI * 2,
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Background
    ctx.fillStyle = '#10101A';
    ctx.fillRect(0, 0, W, H);

    // Grid
    const gs = 42;
    ctx.strokeStyle = 'rgba(139,121,255,0.055)';
    ctx.lineWidth = 0.5;
    for (let x = 0; x < W; x += gs) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
    for (let y = 0; y < H; y += gs) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }

    // Connections
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const d  = Math.sqrt(dx * dx + dy * dy);
        if (d < 110) {
          const alpha = (1 - d / 110) * 0.38;
          ctx.beginPath();
          ctx.strokeStyle = `rgba(139,121,255,${alpha})`;
          ctx.lineWidth = 0.75;
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.stroke();
        }
      }
    }

    // Nodes
    const t = frame * 0.018;
    nodes.forEach(n => {
      const pulse = Math.sin(t + n.phase) * 0.28 + 0.72;
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle   = `rgba(${n.hue},${pulse})`;
      ctx.strokeStyle = `rgba(${n.hue},0.65)`;
      ctx.lineWidth   = 1;
      ctx.fill();
      ctx.stroke();

      n.x += n.vx; n.y += n.vy;
      if (n.x < 0 || n.x > W) n.vx *= -1;
      if (n.y < 0 || n.y > H) n.vy *= -1;
    });

    // Floating code snippets
    ctx.font = '10px "JetBrains Mono", monospace';
    SNIPPETS.forEach(s => {
      const yo = Math.sin(t * 0.7 + s.xr * 8) * 1.8;
      ctx.fillStyle = 'rgba(195,187,255,0.18)';
      ctx.fillText(s.text, s.xr * W, s.yr * H + yo);
    });

    frame++;
    raf = requestAnimationFrame(draw);
  }

  const ro = new ResizeObserver(resize);
  ro.observe(canvas);
  resize();

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    ctx.fillStyle = '#10101A';
    ctx.fillRect(0, 0, W, H);
  } else {
    draw();
  }

  // Clean up when navigating away
  document.addEventListener('astro:before-swap', () => {
    cancelAnimationFrame(raf);
    ro.disconnect();
  });
</script>
