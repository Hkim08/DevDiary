---
// src/components/CoverArt.astro
// Inline SVG illustrations for blog post cards and hero images

interface Props {
  type: 'neural' | 'radar' | 'doc' | 'code' | 'product';
  height?: number;
  title?: string;
  slug?: string;
}

const { type, height = 200, title, slug } = Astro.props;
const label = title ? title.toUpperCase().slice(0, 28) : '';
const W = 640, H = 400;

function glow(id: string, blur = 3): string {
  return `<filter id="${id}"><feGaussianBlur stdDeviation="${blur}" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>`;
}

function noise(id: string, freq = '.6'): string {
  return `<filter id="${id}"><feTurbulence type="fractalNoise" baseFrequency="${freq}" numOctaves="3" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/><feBlend in="SourceGraphic" mode="overlay"/></filter>`;
}
