---
// src/components/PostsGrid.astro
import CoverArt from './CoverArt.astro';
import { featuredPost, recentPosts } from '../data/posts';
---

<section class="posts-section container" aria-labelledby="posts-heading">
  <div class="section-header">
    <h2 class="section-label" id="posts-heading">Featured from the diary</h2>
    <a href="/blog" class="see-all">All posts →</a>
  </div>

  <div class="posts-grid">
    <!-- BIG featured card -->
    <article class="card-big">
      <a href={`/blog/${featuredPost.slug}`} class="card-link" aria-label={featuredPost.title}>
        <div class="card-cover">
          <CoverArt type={featuredPost.coverType} height={210} title={featuredPost.title} />
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class={`badge ${featuredPost.categoryStyle}`}>{featuredPost.category}</span>
            <span class="card-date font-mono">{featuredPost.date}</span>
          </div>
          <h3 class="card-title">{featuredPost.title}</h3>
          <p class="card-desc">{featuredPost.description}</p>
        </div>
        <div class="card-footer">
          <span class="read-time font-mono">{featuredPost.readTime}</span>
          <span class="card-cta">Read article →</span>
        </div>
      </a>
    </article>

    <!-- Small card stack -->
    <div class="cards-stack">
      {recentPosts.map((post) => (
        <article class="card-sm">
          <a href={`/blog/${post.slug}`} class="card-sm-link" aria-label={post.title}>
            <div class="card-sm-thumb">
              <CoverArt type={post.coverType} height={90} title={post.title} />
            </div>
            <div class="card-sm-body">
              <div class="card-meta">
                <span class={`badge ${post.categoryStyle}`}>{post.category}</span>
                <span class="card-date font-mono">{post.date}</span>
              </div>
              <h3 class="card-sm-title">{post.title}</h3>
              <p class="card-sm-desc">{post.description}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .posts-section {
    padding-block: var(--sp-2xl);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-lg);
  }

  .see-all {
    font-size: 13px;
    color: var(--ink3);
    transition: color 0.15s;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .see-all:hover { color: var(--v2); }

  .posts-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 14px;
  }

  /* ── Big card ── */
  .card-big {
    background: var(--bg2);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .card-big:hover {
    border-color: rgba(139,121,255,.38);
    transform: translateY(-2px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-cover { line-height: 0; }

  .card-body {
    padding: 22px;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .card-date {
    font-size: 11px;
    color: var(--ink3);
  }

  .card-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .card-desc {
    font-size: 13px;
    color: var(--ink2);
    line-height: 1.62;
  }

  .card-footer {
    padding: 14px 22px;
    border-top: 1px solid var(--b1);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .read-time { font-size: 11px; color: var(--ink3); }

  .card-cta {
    font-size: 13px;
    color: var(--v2);
    font-weight: 500;
  }

  /* ── Small cards ── */
  .cards-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card-sm {
    background: var(--bg2);
    border: 1px solid var(--b1);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .card-sm:hover {
    border-color: rgba(139,121,255,.32);
    transform: translateX(3px);
  }

  .card-sm-link {
    display: grid;
    grid-template-columns: 90px 1fr;
    height: 100%;
  }

  .card-sm-thumb {
    line-height: 0;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-sm-thumb svg { height: 100%; object-fit: cover; }

  .card-sm-body {
    padding: 14px 16px;
  }

  .card-sm-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
    letter-spacing: -0.015em;
    margin-bottom: 5px;
  }

  .card-sm-desc {
    font-size: 12px;
    color: var(--ink2);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .cards-stack {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .cards-stack { grid-template-columns: 1fr; }
    .card-sm-link { grid-template-columns: 80px 1fr; }
  }
</style>
